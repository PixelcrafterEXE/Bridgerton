# ──────────────────────────────────────────────
# Matrix server identity
# ──────────────────────────────────────────────
MATRIX_SERVER_NAME=example.com
SYNAPSE_REPORT_STATS=no

# No external ports are needed — Synapse is internal bridge infrastructure only.

# ──────────────────────────────────────────────
# Admin account created on first boot
# ──────────────────────────────────────────────
SYNAPSE_ADMIN_USER=admin
SYNAPSE_ADMIN_PASSWORD=changeme

# ──────────────────────────────────────────────
# Synapse secrets — generate with:
#   openssl rand -hex 32
# ──────────────────────────────────────────────
SYNAPSE_REGISTRATION_SECRET=
SYNAPSE_MACAROON_SECRET=
SYNAPSE_FORM_SECRET=

# ──────────────────────────────────────────────
# Database passwords — generate with:
#   openssl rand -hex 16
# ──────────────────────────────────────────────
SYNAPSE_DB_PASSWORD=
SIGNAL_DB_PASSWORD=
WHATSAPP_DB_PASSWORD=

# ──────────────────────────────────────────────
# Bridge application-service tokens — generate with:
#   openssl rand -hex 32
#
# AS_TOKEN  = token the bridge uses to authenticate to Synapse
# HS_TOKEN  = token Synapse uses to authenticate to the bridge
# ──────────────────────────────────────────────
WHATSAPP_AS_TOKEN=
WHATSAPP_HS_TOKEN=

SIGNAL_AS_TOKEN=
SIGNAL_HS_TOKEN=
